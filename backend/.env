# 搜索引擎配置
SEARCH_API=tavily          # Options: duckduckgo, tavily

# LLM 配置 (使用阿里云百炼 DashScope 原生 API)
LLM_PROVIDER=custom             # Options: ollama, lmstudio, custom
LLM_MODEL_ID=qwen3-max           # 百炼模型: qwen-max, qwen-plus, qwen-turbo, qwen3-235b-a22b 等
LLM_API_KEY=sk-******

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志级别
LOG_LEVEL=INFO

# Tavily API Key（使用 Tavily 搜索时需要）
TAVILY_API_KEY=tvly-*****

# 本地模型配置 (Ollama / LMStudio)
# LLM_PROVIDER=ollama
# LOCAL_LLM=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# LLM_PROVIDER=lmstudio
# LOCAL_LLM=qwen_qwq-32b
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# 研究深度与搜索配置
MAX_WEB_RESEARCH_LOOPS=3
FETCH_FULL_PAGE=True
STRIP_THINKING_TOKENS=True

# Qdrant 向量数据库配置 - 获取API密钥：https://cloud.qdrant.io/
# ================================
# 使用Qdrant云服务 (推荐)
QDRANT_URL=***
QDRANT_API_KEY=***
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30
